# ===== tomo-buy (agentbuy core, Agentcard-funded) =====

# ---- LLM (OpenRouter) — REQUIRED ----
OPENROUTER_API_KEY=sk-or-v1-...
# Model for the in-checkout browser agent (action selection). This is the model that
# decides which element to click/fill from a screenshot + element list. Reliability
# here matters MOST — a weak model returns malformed JSON or grounds to the wrong
# element, which the checkout loop sees as a silent no-op (page never advances).
#
# The checkout engine now drives the browser as a tool-calling Computer-Use Agent
# (CUA): one strong model holds the full task conversation and calls browser +
# capability tools (login / fill_card / fill_otp / fill_shipping). Use a model
# with strong vision + native tool-calling. Recommended for the CUA path:
#   AGENT_MODEL=anthropic/claude-sonnet-4   (or anthropic/claude-opus-4 for hard sites)
# openai/gpt-4o also works (vision + tools). The legacy json-batch act loop
# (playwrightAct) is retained but no longer on the checkout path.
AGENT_MODEL=anthropic/claude-sonnet-4

# Hard cap on CUA tool calls per checkout before it gives up (default 40).
# AGENT_TOOL_CALLS_MAX=40

# ---- Native Anthropic computer-use CUA (recommended for hard sites) ----
# When ANTHROPIC_API_KEY is set, the checkout CUA uses Anthropic's native
# computer-use API instead of the OpenRouter tool-calling loop. The native CUA
# reasons visually from screenshots (trained for it) — fewer "silly" mistakes
# like typing URLs into search bars. Falls back to tool-calling if unset.
# ANTHROPIC_API_KEY=sk-ant-...
# Model for native CUA (default: claude-opus-4-5-20251001). Opus is recommended
# for complex checkouts; Sonnet is faster and cheaper for simpler flows.
# CUA_NATIVE_MODEL=claude-opus-4-5-20251001
# Set CUA_MODE=tool-calling to force the old OpenRouter loop even if ANTHROPIC_API_KEY is set.
# CUA_MODE=tool-calling
# Model for discovery / structured extraction (defaults to AGENT_MODEL). This is
# pure text→JSON extraction, so the cheapest capable model is fine here.
INTENT_MODEL=google/gemini-2.5-flash-lite
# Budget alternative (cheapest, but the act loop is noticeably less reliable on
# moderately-hard sites — it may stall and burn LLM budget):
# AGENT_MODEL=google/gemini-2.5-flash-lite

# ---- In-checkout agent provider (optional) ----
# openrouter (default) = route the page-action loop through OpenRouter.
# gemini               = route it through Google Gemini (production-recommended).
#   Requires GEMINI_API_KEY; otherwise falls back to OpenRouter. Discovery,
#   extraction, and the planner stay on OpenRouter regardless.
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AI...
# GEMINI_MODEL=gemini-2.5-flash-lite

# ---- Product discovery (Exa) — for NL search; URL mode also uses Playwright ----
EXA_API_KEY=exa_...

# ---- Planning agent + agent identities ----
# Model for the top-level planner + identity resolver (defaults to INTENT_MODEL)
# PLANNER_MODEL=openai/gpt-4o-mini
# Symmetric key encrypting the local secret vault (~/.tomo/vault.json).
# REQUIRED to log in with an agent identity (vaulted password) or a session token.
VAULT_KEY=change-me-to-a-long-random-string
# Composio key for the user's connected email (account detection + OTP reading).
# When set, the real Gmail client reads the connected inbox to detect existing
# accounts and pull one-time codes (connected_otp login). When unset, the agent
# defaults to a fresh agent identity rather than the user's account.
# COMPOSIO_API_KEY=ak_...
# AgentMail powers agent-identity inboxes (signup + OTP). Optional; without it,
# agent identities use a local placeholder email and skip email OTP.
# AGENTMAIL_API_KEY=am_...

# ---- Funding (Agentcard) ----
# agentcard = issue a real single-use card per purchase (REAL MONEY).
# static    = use the CARD_* values below instead (debugging only).
FUNDING=agentcard
# Buffer over item price to cover tax/shipping when sizing the card (0.15 = 15%)
AGENTCARD_BUFFER_PCT=0.15
# Hard ceiling (dollars) on any single issued card
AGENTCARD_MAX_AMOUNT=500
# Optional: path to a globally-installed agentcard binary (else uses `npx agentcard@latest`)
# AGENTCARD_BIN=/usr/local/bin/agentcard

# ---- Static card (only used when FUNDING=static) ----
# CARD_NUMBER=4111111111111111
# CARD_EXPIRY=12/29
# CARD_CVV=123
# CARDHOLDER_NAME=John Doe

# ---- Billing address (used for AVS during checkout) ----
BILLING_STREET=123 Main St
BILLING_CITY=Austin
BILLING_STATE=TX
BILLING_ZIP=78701
BILLING_COUNTRY=US

# ---- Default shipping (optional; can be passed per /api/buy) ----
SHIPPING_NAME=John Doe
SHIPPING_STREET=123 Main St
SHIPPING_CITY=Austin
SHIPPING_STATE=TX
SHIPPING_ZIP=78701
SHIPPING_COUNTRY=US
SHIPPING_EMAIL=john@example.com
SHIPPING_PHONE=512-555-0100

# ---- Browser ----
# false = visible Chrome window (watch the checkout); true = headless
HEADLESS=false
# Browser runtime: local (default) = local Playwright Chrome (runs out of the box).
# browserbase = managed stealth browsers (production-recommended). Requires
# BROWSERBASE_API_KEY + BROWSERBASE_PROJECT_ID; otherwise falls back to local.
# Per-domain cache follows the runtime: local uses a file cache
# (~/.tomo/cache/{domain}.json); browserbase uses server-side Contexts.
# BROWSER_RUNTIME=browserbase
# BROWSERBASE_API_KEY=bb_...
# BROWSERBASE_PROJECT_ID=...
# Checkout backend: local (default) = local Playwright + our CUA loop (card via CDP).
# browserbase-agents = Browserbase's MANAGED Agents service drives a remote browser
# from a natural-language task and returns structured output. Primary when set;
# requires BROWSERBASE_API_KEY (else falls back to local). Card/login secrets are
# NEVER sent to Browserbase — it drives to the payment page and parks, and the local
# CDP engine enters the card + places the order (and is the fallback on BB failure).
# BROWSER_BACKEND=browserbase-agents
# Poll timeout (ms) for a Browserbase Agents run to finish (default 300000 = 5 min).
# AGENT_RUN_TIMEOUT_MS=300000
# Connect to your already-running Chrome (bypasses bot detection — real fingerprint/cookies).
# Start Chrome first: open -a "Google Chrome" --args --remote-debugging-port=9222
# Then set: BROWSER_CDP_URL=http://localhost:9222
# BROWSER_CDP_URL=http://localhost:9222

# ---- Server ----
PORT=3000
