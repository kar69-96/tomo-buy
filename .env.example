# ===== tomo-buy (agentbuy core, Agentcard-funded) =====

# ---- LLM (OpenRouter) — REQUIRED ----
OPENROUTER_API_KEY=sk-or-v1-...
# Model for the in-checkout browser agent (action selection)
AGENT_MODEL=openai/gpt-4o-mini
# Model for discovery / structured extraction (defaults to AGENT_MODEL)
INTENT_MODEL=openai/gpt-4o-mini
# Recommended vision model: cheaper than gpt-4o-mini ($0.10/$0.40 vs $0.15/$0.60)
# and vision-capable. Served by OpenRouter, so no extra key is needed:
# AGENT_MODEL=google/gemini-2.5-flash-lite
# INTENT_MODEL=google/gemini-2.5-flash-lite

# ---- In-checkout agent provider (optional) ----
# openrouter (default) = route the page-action loop through OpenRouter.
# gemini               = route it through Google Gemini (production-recommended).
#   Requires GEMINI_API_KEY; otherwise falls back to OpenRouter. Discovery,
#   extraction, and the planner stay on OpenRouter regardless.
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AI...
# GEMINI_MODEL=gemini-2.5-flash-lite

# ---- Product discovery (Exa) — for NL search; URL mode also uses Playwright ----
EXA_API_KEY=exa_...

# ---- Planning agent + agent identities ----
# Model for the top-level planner + identity resolver (defaults to INTENT_MODEL)
# PLANNER_MODEL=openai/gpt-4o-mini
# Symmetric key encrypting the local secret vault (~/.tomo/vault.json).
# REQUIRED to log in with an agent identity (vaulted password) or a session token.
VAULT_KEY=change-me-to-a-long-random-string
# Composio key for the user's connected email (account detection + OTP reading).
# When set, the real Gmail client reads the connected inbox to detect existing
# accounts and pull one-time codes (connected_otp login). When unset, the agent
# defaults to a fresh agent identity rather than the user's account.
# COMPOSIO_API_KEY=ak_...
# AgentMail powers agent-identity inboxes (signup + OTP). Optional; without it,
# agent identities use a local placeholder email and skip email OTP.
# AGENTMAIL_API_KEY=am_...

# ---- Funding (Agentcard) ----
# agentcard = issue a real single-use card per purchase (REAL MONEY).
# static    = use the CARD_* values below instead (debugging only).
FUNDING=agentcard
# Buffer over item price to cover tax/shipping when sizing the card (0.15 = 15%)
AGENTCARD_BUFFER_PCT=0.15
# Hard ceiling (dollars) on any single issued card
AGENTCARD_MAX_AMOUNT=500
# Optional: path to a globally-installed agentcard binary (else uses `npx agentcard@latest`)
# AGENTCARD_BIN=/usr/local/bin/agentcard

# ---- Static card (only used when FUNDING=static) ----
# CARD_NUMBER=4111111111111111
# CARD_EXPIRY=12/29
# CARD_CVV=123
# CARDHOLDER_NAME=John Doe

# ---- Billing address (used for AVS during checkout) ----
BILLING_STREET=123 Main St
BILLING_CITY=Austin
BILLING_STATE=TX
BILLING_ZIP=78701
BILLING_COUNTRY=US

# ---- Default shipping (optional; can be passed per /api/buy) ----
SHIPPING_NAME=John Doe
SHIPPING_STREET=123 Main St
SHIPPING_CITY=Austin
SHIPPING_STATE=TX
SHIPPING_ZIP=78701
SHIPPING_COUNTRY=US
SHIPPING_EMAIL=john@example.com
SHIPPING_PHONE=512-555-0100

# ---- Browser ----
# false = visible Chrome window (watch the checkout); true = headless
HEADLESS=false
# Browser runtime: local (default) = local Playwright Chrome (runs out of the box).
# browserbase = managed stealth browsers (production-recommended). Requires
# BROWSERBASE_API_KEY + BROWSERBASE_PROJECT_ID; otherwise falls back to local.
# Per-domain cache follows the runtime: local uses a file cache
# (~/.tomo/cache/{domain}.json); browserbase uses server-side Contexts.
# BROWSER_RUNTIME=browserbase
# BROWSERBASE_API_KEY=bb_...
# BROWSERBASE_PROJECT_ID=...

# ---- Server ----
PORT=3000
