# ---- Payment Credentials (never exposed to LLM) ----
CARD_NUMBER=4111111111111111
CARD_EXPIRY=12/25
CARD_CVV=123
CARDHOLDER_NAME=John Doe

# ---- Billing Address ----
BILLING_STREET=123 Main St
BILLING_CITY=Austin
BILLING_STATE=TX
BILLING_ZIP=78701
BILLING_COUNTRY=US

# ---- Default Shipping (optional, can pass per-purchase) ----
SHIPPING_NAME=John Doe
SHIPPING_STREET=123 Main St
SHIPPING_CITY=Austin
SHIPPING_STATE=TX
SHIPPING_ZIP=78701
SHIPPING_COUNTRY=US
SHIPPING_EMAIL=john@example.com
SHIPPING_PHONE=512-555-0100

# ---- API Keys ----
GOOGLE_API_KEY=AIza...
GOOGLE_API_KEY_QUERY=AIza...
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PROJECT_ID=proj_...

# ---- Coinbase Onramp (CDP) ----
# Get these from portal.cdp.coinbase.com
# Required for wallet funding via debit card / Apple Pay (Phase 7)
CDP_PROJECT_ID=your-project-id
CDP_API_KEY_NAME=your-key-name
CDP_API_KEY_ID=your-key-id
CDP_API_KEY_SECRET=your-base64-encoded-secret

# ---- Blockchain ----
BASE_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
NETWORK=base-sepolia

# ---- Firecrawl (self-hosted or cloud) ----
# Default: http://localhost:3002 (self-hosted via pnpm firecrawl:start)
# Set to https://api.firecrawl.dev for Firecrawl cloud
FIRECRAWL_BASE_URL=http://localhost:3002
FIRECRAWL_API_KEY=fc-...

# ---- Server ----
PORT=3000

# ---- Bloon Master Wallet (auto-generated on first run if not set) ----
BLOON_MASTER_PRIVATE_KEY=0x...
