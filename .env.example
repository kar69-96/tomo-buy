# ===== tomo-buy (agentbuy core, Agentcard-funded) =====

# ---- LLM (OpenRouter) — REQUIRED ----
OPENROUTER_API_KEY=sk-or-v1-...
# Model for the in-checkout browser agent (action selection)
AGENT_MODEL=openai/gpt-4o-mini
# Model for discovery / structured extraction (defaults to AGENT_MODEL)
INTENT_MODEL=openai/gpt-4o-mini

# ---- Product discovery (Exa) — for NL search; URL mode also uses Playwright ----
EXA_API_KEY=exa_...

# ---- Funding (Agentcard) ----
# agentcard = issue a real single-use card per purchase (REAL MONEY).
# static    = use the CARD_* values below instead (debugging only).
FUNDING=agentcard
# Buffer over item price to cover tax/shipping when sizing the card (0.15 = 15%)
AGENTCARD_BUFFER_PCT=0.15
# Hard ceiling (dollars) on any single issued card
AGENTCARD_MAX_AMOUNT=500
# Optional: path to a globally-installed agentcard binary (else uses `npx agentcard@latest`)
# AGENTCARD_BIN=/usr/local/bin/agentcard

# ---- Static card (only used when FUNDING=static) ----
# CARD_NUMBER=4111111111111111
# CARD_EXPIRY=12/29
# CARD_CVV=123
# CARDHOLDER_NAME=John Doe

# ---- Billing address (used for AVS during checkout) ----
BILLING_STREET=123 Main St
BILLING_CITY=Austin
BILLING_STATE=TX
BILLING_ZIP=78701
BILLING_COUNTRY=US

# ---- Default shipping (optional; can be passed per /api/buy) ----
SHIPPING_NAME=John Doe
SHIPPING_STREET=123 Main St
SHIPPING_CITY=Austin
SHIPPING_STATE=TX
SHIPPING_ZIP=78701
SHIPPING_COUNTRY=US
SHIPPING_EMAIL=john@example.com
SHIPPING_PHONE=512-555-0100

# ---- Browser ----
# false = visible Chrome window (watch the checkout); true = headless
HEADLESS=false

# ---- Server ----
PORT=3000
