# Tomo-buy environment — placeholders only. Copy to .env and fill locally.
# NEVER commit real secrets. .env is gitignored.

# --- Agentcard (funding rail; Organizations REST) ---
AGENTCARD_API_BASE=https://api.agentcard.example/v1
AGENTCARD_API_KEY=replace_me

# --- Browserbase (headless server-side browser for Lane B) ---
BROWSERBASE_API_KEY=replace_me
BROWSERBASE_PROJECT_ID=replace_me

# --- Temporal (orchestration; free local dev server) ---
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default

# --- Vault encryption (server-side only; never reaches the LLM) ---
VAULT_KMS_KEY_ID=replace_me
