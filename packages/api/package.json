{
  "name": "@tomo/api",
  "version": "0.0.0",
  "private": true,
  "description": "Internal service contracts (§14) — the Lane B P2 composition root. Hono over the merged Wave-2 packages.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "tsup --watch",
    "start": "node dist/start-server.js",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@tomo/core": "workspace:*",
    "@tomo/funding": "workspace:*",
    "@tomo/intent": "workspace:*",
    "@tomo/router": "workspace:*",
    "@tomo/profiles": "workspace:*",
    "@tomo/vaults": "workspace:*",
    "@tomo/executor": "workspace:*",
    "@tomo/orchestrator": "workspace:*",
    "@tomo/worker": "workspace:*",
    "@temporalio/client": "^1.18.1",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.18.1",
    "@temporalio/worker": "^1.18.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
